# === Database ===
# من Supabase أو Neon (connection string بتاعة Postgres)
DATABASE_URL=

# === Auth ===
# أي نص عشوائي طويل (تقدر تولده بـ: openssl rand -base64 32)
JWT_SECRET=

# === Google Ads API ===
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# === Meta Marketing API (لربط حسابات Meta Ads) ===
# نفس الـ App ID/Secret ممكن يكونوا نفس تطبيق واتساب لو فعّلت Marketing API
# كـ "Product" إضافي على نفس تطبيق Meta for Developers، أو تطبيق منفصل
META_APP_ID=
META_APP_SECRET=

# === رابط التطبيق الأساسي (لازم لبناء روابط الـ OAuth redirect بشكل صحيح) ===
# مثال: https://adloop.app في الإنتاج، أو http://localhost:3000 محلياً
APP_URL=http://localhost:3000

# === Meta / WhatsApp ===
WHATSAPP_VERIFY_TOKEN=

# === Salla (إيكومرس) ===
# سر التحقق من توقيع الـ webhook - من لوحة تحكم شركاء سلة
SALLA_WEBHOOK_SECRET=

# === فحص الموقع (Site Scan) ===
# ScreenshotAPI.net - مجاني حتى 200 صورة/شهر بدون بطاقة ائتمان
SCREENSHOT_API_KEY=
# Google PageSpeed Insights - مجاني حتى 25000 طلب/يوم، نفس مفتاح Google Cloud
GOOGLE_PAGESPEED_API_KEY=
# مفيش حاجة تتحط هنا فعلياً - بنستخدم open.er-api.com، مجاني وبدون
# مفتاح API خالص. السطر ده كان افتراض قديم غير دقيق، مسيبه فاضي عمداً.
EXCHANGE_RATE_API_KEY=

# === Claude API (لطبقة الـ AI insights) ===
ANTHROPIC_API_KEY=

# === Sentry (مراقبة الأخطاء - خطة Developer المجانية كافية للبداية) ===
# اتسجل مجاناً على sentry.io، اعمل مشروع Next.js، وهيديك القيم دي
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# === النسخ الاحتياطي المستقل (Vercel Blob) ===
# بيتولّد تلقائياً لما تفعّل Blob Storage من لوحة تحكم Vercel للمشروع
BLOB_READ_WRITE_TOKEN=

# === تيك توك (Business API - مختلفة عن Login Kit العام) ===
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=

# === محرك الإسناد - مصادقة داخلية مع wa-conversion-tracker ===
# نفس القيمة بالظبط لازم تتحط في متغيرات wa-conversion-tracker
INTERNAL_SERVICE_SECRET=

# === ويب هوك ماسنجر (Click-to-Messenger) - تحقق جودة ليدز حقيقية ===
META_APP_SECRET=
META_MESSENGER_VERIFY_TOKEN=

# === إشعارات الموبايل (Web Push) ===
# مفاتيح VAPID - تتولّد مرة واحدة بأمر: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=
# اختياري - افتراضياً 48 ساعة
PUSH_INACTIVITY_THRESHOLD_HOURS=48

# === الدفع والاشتراكات (Paymob) ===
PAYMOB_SECRET_KEY=
PAYMOB_PUBLIC_KEY=
# رقم integration_id لطريقة الدفع (كارت غالباً) - من لوحة تحكم Paymob
# Developers → Payment Integrations
PAYMOB_INTEGRATION_ID=
# من Settings → Payment Integrations → HMAC في لوحة تحكم Paymob
PAYMOB_HMAC_SECRET=
# بالقرش (أصغر وحدة عملة) - مثال: 50000 = 500 جنيه
PLAN_PRICE_STARTER_CENTS=
PLAN_PRICE_PRO_CENTS=

# === فورم الليدز داخل ميتا (Instant Forms) ===
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=

# === تشفير التوكنات (حرج - بدونه توكنات جوجل/ميتا متخزنة بدون حماية) ===
# ولّده بالأمر ده مرة واحدة بس، واحفظه في مكان آمن - لو ضاع، كل حسابات
# جوجل/ميتا المربوطة لازم تتربط تاني من الصفر:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# === حماية الحساب (Cloudflare Turnstile - مجاني بالكامل) ===
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# === Cron ===
# نص عشوائي طويل بتحطه هنا وفي إعدادات Vercel - بيحمي endpoint المزامنة
# اليومية من إن أي حد تاني يقدر يشغّلها يدوي
CRON_SECRET=

# === الإيميلات (Resend - مجاني حتى 3000 إيميل/شهر) ===
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=
